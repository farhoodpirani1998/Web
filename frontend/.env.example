# Website Public API base URL (Website Product Architecture — Public API contract).
# The frontend never talks to the admin API — only this base URL is ever configured.
VITE_PUBLIC_API_BASE_URL=http://localhost:3000/api/public

# The site's active locale. Phase 1 ships Persian-only, so this drives
# <html lang/dir> at bootstrap rather than any URL segment.
# Supported locales: fa (Persian, RTL), en (English, LTR).
VITE_DEFAULT_LOCALE=fa

# Request timeout (ms) for the Public API client.
VITE_API_TIMEOUT_MS=15000

# Application environment label (used for non-sensitive diagnostics only).
VITE_APP_ENV=development
