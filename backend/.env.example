# --- Runtime environment ---
# Required for the production synchronize safety check (see
# src/config/database-synchronize.config.ts). Must be exactly "production"
# in production deployments — the app refuses to start with synchronize
# enabled while this is set to "production".
NODE_ENV=development

# --- This backend's own database (independent from SMS's database) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nhg_website
DATABASE_USER=nhg_website
DATABASE_PASSWORD=changeme
# Auto-sync entities to schema. Defaults to on outside production, off in
# production, and startup fails hard if this ever resolves to true while
# NODE_ENV=production. Leave unset in production; use migrations instead.
DATABASE_SYNCHRONIZE=true

# --- SMS identity trust (public-key verification only — no shared DB, no shared secret) ---
# The RS256 public key SMS signs user JWTs with. This backend verifies signatures only;
# it never calls into SMS's database or shares its RBAC tables.
SMS_JWT_PUBLIC_KEY_PATH=./keys/sms-public-key.pem
SMS_JWT_ISSUER=nhg-sms

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO) ---
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
LOCAL_STORAGE_PATH=./uploads

# --- Trust proxy (see main.ts) ---
# Set this when the app runs behind a reverse proxy/load balancer (nginx,
# ALB, Cloudflare, etc) so express reads the real client IP from
# X-Forwarded-For instead of the proxy's own address — matters for
# throttling and any IP-based logic. Accepts "true", a hop count (e.g.
# "1" for a single trusted proxy), or a comma-separated list of specific
# IPs/CIDR ranges/keywords ("loopback,linklocal,uniquelocal"). Left
# unset/empty, falls back to "false" (today's default, unchanged) — fine
# for local development without a proxy in front.
TRUST_PROXY=

# --- CORS (see main.ts) ---
# Comma-separated allow-list of origins allowed to read responses from a
# browser, e.g. "https://nhg.example,https://admin.nhg.example". Left
# unset/empty, all origins are allowed (today's default). Admin routes
# are still protected by the SMS-JWT guard regardless of origin — this
# only controls which origins a browser will let read the response.
CORS_ALLOWED_ORIGINS=

# --- Request payload limits (see main.ts) ---
# Byte ceiling for a single JSON / urlencoded request body (protects
# against oversized-payload abuse). Both optional; left unset, each
# falls back to 1 MiB (1048576 bytes) below — more generous than
# express's own built-in 100kb default, but still bounded.
BODY_LIMIT_JSON_BYTES=1048576
BODY_LIMIT_URLENCODED_BYTES=1048576

# --- Public site (see public-api/sitemap/public-sitemap.controller.ts) ---
# Absolute origin the public site is served at, no trailing slash, e.g.
# "https://nedayehaghighat.example". Used to build absolute <loc> URLs
# in /sitemap.xml. Left unset, falls back to http://localhost:{PORT}.
PUBLIC_SITE_URL=

PORT=3100

# --- API documentation (see main.ts) ---
# Swagger UI + OpenAPI JSON are mounted at /api/docs. On by default
# outside production; set to "true" to opt into exposing them in a
# production deployment too.
SWAGGER_ENABLED=false

# --- Redis (see core/redis/redis.module.ts) ---
# Connection for RedisService (get/set-with-TTL/delete). All optional —
# left unset, defaults to a local Redis on its standard port with no
# auth, db 0.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# --- Rate limiting (see app.module.ts / public-api/common/public-rate-limit.constants.ts) ---
# All optional. TTL is the throttling window in milliseconds; LIMIT is
# the max requests allowed per client within that window. Left unset,
# each falls back to today's values (shown below) — behavior is
# unchanged until a deployment opts in.
# Global floor applied to every route (admin, auth, public):
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=300
# Tighter override for public/* content-read endpoints:
THROTTLE_PUBLIC_TTL_MS=60000
THROTTLE_PUBLIC_LIMIT=120
# Stricter still, for any public endpoint that accepts user input (a
# contact/inquiry form, newsletter signup, etc) rather than only
# serving cached reads. No such endpoint exists in this codebase yet —
# this is configured and ready for the first one that's added.
THROTTLE_PUBLIC_FORM_TTL_MS=60000
THROTTLE_PUBLIC_FORM_LIMIT=5
