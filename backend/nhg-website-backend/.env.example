# --- Runtime environment ---
# Required for the production synchronize safety check (see
# src/config/database-synchronize.config.ts). Must be exactly "production"
# in production deployments — the app refuses to start with synchronize
# enabled while this is set to "production".
NODE_ENV=development

# --- This backend's own database (independent from SMS's database) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nhg_website
DATABASE_USER=nhg_website
DATABASE_PASSWORD=changeme
# Auto-sync entities to schema. Defaults to on outside production, off in
# production, and startup fails hard if this ever resolves to true while
# NODE_ENV=production. Leave unset in production; use migrations instead.
DATABASE_SYNCHRONIZE=true

# --- SMS identity trust (public-key verification only — no shared DB, no shared secret) ---
# The RS256 public key SMS signs user JWTs with. This backend verifies signatures only;
# it never calls into SMS's database or shares its RBAC tables.
SMS_JWT_PUBLIC_KEY_PATH=./keys/sms-public-key.pem
SMS_JWT_ISSUER=nhg-sms

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO) ---
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
LOCAL_STORAGE_PATH=./uploads

# --- CORS (see main.ts) ---
# Comma-separated allow-list of origins allowed to read responses from a
# browser, e.g. "https://nhg.example,https://admin.nhg.example". Left
# unset/empty, all origins are allowed (today's default). Admin routes
# are still protected by the SMS-JWT guard regardless of origin — this
# only controls which origins a browser will let read the response.
CORS_ALLOWED_ORIGINS=

PORT=3100
